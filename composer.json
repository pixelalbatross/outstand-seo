{
	"name": "outstand/seo",
	"description": "One block-editor SEO UI, powered by your engine in the background.",
	"type": "wordpress-plugin",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "Sérgio Santos",
			"homepage": "https://s3rgiosan.dev"
		}
	],
	"autoload": {
		"psr-4": {
			"Outstand\\WP\\SEO\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Outstand\\WP\\SEO\\Tests\\Unit\\": "tests/php/unit/"
		}
	},
	"require": {
		"php": "^8.2",
		"composer-plugin-api": "^2.3",
		"yahnis-elsts/plugin-update-checker": "^5.6"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"pixelalbatross/coding-standards": "dev-main",
		"yoast/phpunit-polyfills": "^1.1"
	},
	"scripts": {
		"lint": "phpcs .",
		"lint-fix": "phpcbf .",
		"test": "phpunit"
	},
	"extra": {
		"installer-name": "outstand-seo"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"optimize-autoloader": true
	}
}
